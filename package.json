{
  "name": "opencode-indexer",
  "version": "0.1.0",
  "description": "Semantic code search plugin for OpenCode — tree-sitter AST indexing with LanceDB vector store",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/jbpraxxys/opencode-indexer.git"
  },
  "keywords": [
    "opencode",
    "code-search",
    "vector-search",
    "lancedb",
    "tree-sitter",
    "ai-tools"
  ],
  "main": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./tui": "./src/tui.tsx"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "overrides": {
    "tree-sitter": "^0.25.0"
  },
  "dependencies": {
    "@lancedb/lancedb": "^0.26.2",
    "@opencode-ai/plugin": "^1.14.0",
    "@opentui/core": "^0.3.4",
    "@opentui/solid": "^0.3.4",
    "apache-arrow": "^18.1.0",
    "better-sqlite3": "^12.10.0",
    "chokidar": "^5.0.0",
    "glob": "^11.0.0",
    "ignore": "^7.0.5",
    "ollama": "^0.5.0",
    "solid-js": "^1.9.12",
    "tree-sitter": "^0.25.0",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-php": "^0.24.2",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-typescript": "^0.23.2",
    "uuid": "^11.0.0",
    "web-tree-sitter": "^0.26.9"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "solid-js": "^1.9.12",
    "typescript": "^5.7.0"
  }
}